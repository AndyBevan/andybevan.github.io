---
import BaseLayout from "../layouts/BaseLayout.astro";
import { themes } from "../data/themes";
---
<BaseLayout title="Theme Lab · Andy Bevan">
  <section class="surface">
    <p class="micro-heading">Theme Lab</p>
    <p style="color: var(--color-text-muted); margin-bottom: 1rem;">
      Toggle between the blue palettes while evaluating the writing. This route is unlinked in
      production, so feel free to experiment before locking a direction.
    </p>
    <div class="grid two-column">
      {themes.map((theme) => (
        <article class="post-card" style={`border-color:${theme.palette.border};`}>
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span class="micro-heading">{theme.displayName}</span>
            <span style="font-size:0.85rem;color:var(--color-text-muted);">{theme.description}</span>
          </div>
          <div style="margin:1rem 0;display:flex;gap:0.75rem;">
            <span
              style={`width:36px;height:36px;border-radius:50%;background:${theme.accent};display:inline-flex;align-items:center;justify-content:center;`}
            ></span>
            <span style="font-size:0.85rem;">Accent</span>
          </div>
          <button
            type="button"
            style="padding:0.65rem 1.2rem;border-radius:999px;border:none;background:var(--color-accent);color:#010409;font-weight:600;cursor:pointer;"
            onclick={`window.__applyTheme && window.__applyTheme('${theme.id}')`}
          >
            Apply {theme.displayName}
          </button>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
