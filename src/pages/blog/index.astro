---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { posts } from "../../lib/posts";

const sorted = posts;
---
<BaseLayout title="Blog · Andy Bevan">
  <section class="surface">
    <p class="micro-heading">Journal</p>
    <div class="grid posts-grid">
      {sorted.map(({ slug, frontmatter }) => (
        <article class="post-card">
          <div class="micro-heading">{new Date(frontmatter.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</div>
          <h3><a href={`/blog/${slug}`}>{frontmatter.title}</a></h3>
          <p>{frontmatter.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
