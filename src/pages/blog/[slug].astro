---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { posts } from "../../lib/posts";

export const prerender = true;
export async function getStaticPaths() {
  return posts.map((entry) => ({
    params: { slug: entry.slug }
  }));
}

const slug = Astro.params.slug;
const post = posts.find((entry) => entry.slug === slug);

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { frontmatter, Content } = post;
---
<BaseLayout title={`${frontmatter.title} · Andy Bevan`} description={frontmatter.description}>
  <section class="surface">
    <p class="micro-heading">
      {new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric"
      })}
    </p>
    <h2 style="margin-top: 0.5rem;">{frontmatter.title}</h2>
    <p style="color: var(--color-text-muted); margin-bottom: 1.5rem;">{frontmatter.description}</p>
    <Content />
  </section>
</BaseLayout>
