---
import "../styles/global.css";
import { siteConfig } from "../data/siteConfig";
import ThemeScript from "../components/ThemeScript.astro";

const pageTitle = Astro.props.title ?? siteConfig.title;
const description = Astro.props.description ?? siteConfig.tagline;
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" }
];
const showThemeLab = import.meta.env.DEV;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="theme-color" content="#020617" />
  </head>
  <body>
    <ThemeScript />
    <div class="page">
      <header class="hero">
        <p class="micro-heading">Andy Bevan</p>
        <h1 class="hero-title">{siteConfig.title}</h1>
        <p class="hero-body">
          {siteConfig.tagline} This site is editorial-led, focused on long-form technical notes
          with room for interactive demos when it makes sense.
        </p>
        <div class="accent-pill">Astro · MDX · Live theme lab</div>
        <nav style="margin-top:1.5rem;">
          <ul style="list-style:none;padding:0;display:flex;gap:1rem;margin:0;">
            {navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
            {showThemeLab && (
              <li>
                <a href="/theme-lab" aria-label="Theme lab">Theme Lab</a>
              </li>
            )}
          </ul>
        </nav>
      </header>
      {Astro.props.children}
      <footer>
        <span>© {new Date().getFullYear()} {siteConfig.author}</span>
        <span>
          Built with Astro ·
          <a href={`https://github.com/${siteConfig.social.github}`}>Repo</a>
        </span>
      </footer>
    </div>
  </body>
</html>
